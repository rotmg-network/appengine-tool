{
  "name": "appengine-tool",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n proxy,web -c cyan,magenta \"node server/index.js\" \"vite --host 127.0.0.1\"",
    "dev:proxy": "node server/index.js",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "blueimp-md5": "^2.19.0",
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tough-cookie": "^6.0.1",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/blueimp-md5": "^2.18.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
